function rand(len){
const c="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_";
let s="";
for(let i=0;i<len;i++){
s+=c[Math.floor(Math.random()*c.length)];
}
return s;
}

