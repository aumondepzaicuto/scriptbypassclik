========================= */

function autoClickLamNgay(){

    let buttons=document.querySelectorAll("button");

    for(let btn of buttons){

        let text=(btn.innerText||"").toLowerCase();

        if(text.includes("làm ngay")){

            console.log("Click Làm ngay");

            setTimeout(()=>{
                realClick(btn);
            },2000);

            return true;
        }
    }

    return false;
}

let waitLamNgay=setInterval(()=>{

    if(autoClickLamNgay()){
        clearInterval(waitLamNgay);
    }

},1000);


